# ═══════════════════════════════════════════════════════════
#  .env.example — Copy to .env.local and fill in values
#  SAFE TO COMMIT — contains no real secrets, only key names
#  NEVER commit .env.local, .env.development, .env.production
# ═══════════════════════════════════════════════════════════

# ── Project ───────────────────────────────────────────────
PROJECT_NAME=myapp
NODE_ENV=development

# ── Server Ports ──────────────────────────────────────────
PORT=5000
BACKEND_PORT=5000
FRONTEND_PORT=3000
MONGO_PORT=27017
POSTGRES_PORT=5432
REDIS_PORT=6379

# ── MongoDB ───────────────────────────────────────────────
MONGO_URI=mongodb://admin:changeme@localhost:27017/appdb?authSource=admin
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=
MONGO_DB_NAME=appdb

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_URI=postgresql://admin:changeme@localhost:5432/appdb
POSTGRES_USER=admin
POSTGRES_PASSWORD=
POSTGRES_DB=appdb

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://:password@localhost:6379
REDIS_PASSWORD=

# ── JWT Authentication ────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── External APIs ─────────────────────────────────────────
OPENAI_API_KEY=

# ── CORS / Client URL ─────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Frontend (build-time, not secret) ────────────────────
VITE_API_URL=http://localhost:5000
REACT_APP_API_URL=http://localhost:5000

# ── Deployment ────────────────────────────────────────────
# These go in GitHub Secrets, not here:
# GHCR_TOKEN         → GitHub → Settings → Developer settings → Personal access tokens
# SSH_PRIVATE_KEY    → Private key for your cloud server
# SERVER_HOST        → IP or hostname of staging server
# PROD_SERVER_HOST   → IP or hostname of production server
# SSH_USER           → ubuntu / ec2-user / etc.
